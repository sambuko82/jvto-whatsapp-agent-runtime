{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jvto.local/contracts/trip-brief-v1.json",
  "type": "object",
  "required": ["schema_version", "plan_version"],
  "properties": {
    "schema_version": {"const": "trip-brief-v1"},
    "plan_version": {"type": "integer", "minimum": 1},
    "customer_stage": {"enum": ["exploring", "comparing", "ready_to_book", "paid", "pre_trip", "unknown"]},
    "travel_dates": {
      "type": "object",
      "properties": {
        "start": {"type": ["string", "null"]},
        "end": {"type": ["string", "null"]},
        "flexibility": {"type": ["string", "null"]}
      }
    },
    "pax": {
      "type": "object",
      "properties": {
        "confirmed": {"type": ["integer", "null"], "minimum": 0},
        "tentative": {"type": ["integer", "null"], "minimum": 0},
        "adults": {"type": ["integer", "null"], "minimum": 0},
        "children": {
          "type": "array",
          "items": {"type": "object", "properties": {"age": {"type": ["integer", "null"]}}}
        }
      }
    },
    "current_location": {"type": ["string", "null"]},
    "pickup": {
      "type": "object",
      "properties": {
        "type": {"type": ["string", "null"]},
        "location": {"type": ["string", "null"]},
        "arrival_time": {"type": ["string", "null"]}
      }
    },
    "dropoff": {
      "type": "object",
      "properties": {
        "type": {"type": ["string", "null"]},
        "location": {"type": ["string", "null"]},
        "required_by": {"type": ["string", "null"]}
      }
    },
    "destinations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "priority": {"enum": ["required", "preferred", "optional", "excluded"]}
        }
      }
    },
    "attraction_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "attraction": {"type": "string"},
          "priority": {"enum": ["hard_dependency", "preferred", "optional"]},
          "alternative_accepted": {"type": ["boolean", "null"]}
        }
      }
    },
    "pace_preference": {"enum": ["relaxed", "balanced", "packed", null]},
    "rooming": {
      "type": "object",
      "properties": {
        "room_count": {"type": ["integer", "null"], "minimum": 0},
        "bedding": {"type": ["string", "null"]}
      }
    },
    "luggage": {
      "type": "object",
      "properties": {
        "standard_bags": {"type": ["integer", "null"], "minimum": 0},
        "special_items": {"type": "array", "items": {"type": "string"}}
      }
    },
    "open_questions": {"type": "array", "items": {"type": "string"}},
    "active_blockers": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
